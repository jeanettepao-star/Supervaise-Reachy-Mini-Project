# Secrets — NEVER commit
.env
.env.local
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.Python
*.egg-info/
.pytest_cache/

# Audio model binaries (large, downloaded separately)
voices/*.onnx
voices/*.onnx.json
voices/piper*

# Whisper model cache
.cache/
models/
# But DO commit the trained wake-word classifier — it's the runtime
# artefact we ship (~210 kB single ONNX). Exempt this specific path
# from the generic `models/` rule above.
!wake/models/
!wake/models/*.onnx

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Temp audio
*.wav
*.mp3
!sample_*.wav

# Dashboard runtime state (regenerated by the CLI each turn)
state/
