# Copy this file to .env and fill in your API keys. Never commit .env.
#
# REQUIRED — chat + voice loop
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# The continuous "Hey CJP" / "CJP" wake-word loop uses openWakeWord
# in the browser (Apache-2.0, no access key, no licensing). It is
# enabled automatically when:
#   app/components/wake_word_continuous/dist/wake_word.bundle.js
# AND
#   app/components/wake_word_continuous/models/wake_word.onnx
# both exist. Build the bundle with `npm install && npm run build`
# in the component directory; train the wake_word.onnx classifier
# via the offline pipeline in TRAINING.md. Until both are in place,
# the kiosk falls back to the START/STOP push-to-talk button.

# Legacy local-stack overrides (used only by the offline fallback path).
WHISPER_MODEL=medium
PIPER_BIN=./piper/piper.exe
PIPER_VOICE=./voices/en_US-ryan-high.onnx
