# =============================================================
# CJ Panganiban conversation app — environment template
#
# Copy to one of:
#   <repo>/app/.env            (recommended; most specific)
#   <repo>/.env
#   <cwd>/.env
# All three are searched by cj_chat.py at import time, with later
# values overriding earlier ones (so app/.env wins). To point at a
# specific file, set DOTENV_PATH=<absolute path>.
# =============================================================

# --- Required: API keys -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: Anthropic model overrides --------------------------
# These default to the validated Phase 1-3 choices. Override when you
# want a newer snapshot.
# ROUTER_MODEL=claude-haiku-4-5-20251001
# INFERENCE_MODEL=claude-sonnet-4-6

# --- Optional: OpenAI STT / TTS overrides -------------------------
# Whisper is the only STT model available via the audio.transcriptions
# endpoint; voice / speed defaults below were tuned to CJP's measured
# judicial register.
# OPENAI_STT_MODEL=whisper-1
# OPENAI_TTS_MODEL=tts-1                   # or tts-1-hd for ~2× cost
# OPENAI_TTS_VOICE=onyx                    # CJP default — deep male judicial voice.
                                          # Alternatives:
                                          #   male:   onyx (deep, default) | echo (lighter) | fable (British)
                                          #   female: nova (warm) | shimmer (soft) | alloy (neutral)
# OPENAI_TTS_SPEED=0.95                    # 0.25-4.0; <1 is slower

# --- Optional: explicit .env path ---------------------------------
# DOTENV_PATH=D:\creds\flp\app.env
