# Secrets — NEVER commit
.env
.env.local
*.key
**/.env
**/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.Python
*.egg-info/
.pytest_cache/
**/.venv/
# PLAN-0008 training venv (sibling to the kiosk runtime venv —
# isolated so torch/audiomentations/openwakeword don't bloat the
# runtime image). Multi-gigabyte; never committed.
**/.venv-training/
# Legacy venv snapshots kept as fallback during the D:→C: consolidation
# (and any future venv migration). Never committed.
**/.venv.old/

# Large model/binary assets (each user installs locally)
app/voices/*.onnx
app/voices/*.onnx.json
app/piper/
**/piper/piper.exe
**/piper/*.dll
**/piper/espeak-ng-data/

# Whisper model cache
.cache/
models/
# But DO commit the trained wake-word classifier — it's the runtime
# artefact we ship. ~210 kB single ONNX. Exempt this specific path
# from the generic `models/` rule above.
!app/wake/models/
!app/wake/models/*.onnx

# Temp audio
*.wav
*.mp3
!sample_*.wav

# Dashboard runtime state (regenerated by the CLI each turn)
app/state/

# OS / IDE
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp

# Claude Code per-project local settings (machine-specific)
.claude/settings.local.json
# Claude Code per-project session/state cache (machine-specific)
.claude/
